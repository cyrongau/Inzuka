rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================================
    // Primitives
    // =========================================================================
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "cyrongau@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isFamilyMember(familyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/families/$(familyId)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    function isFamilyOwner(familyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/families/$(familyId)) &&
        get(/databases/$(database)/documents/families/$(familyId)).data.ownerId == request.auth.uid;
    }

    // =========================================================================
    // Validation Helpers
    // =========================================================================
    function isValidUser(data) {
      // Must be strict keys to avoid shadow properties during create, but since map.keys().hasAll is all we have,
      // we check hasAll and then during update we check affectedKeys().hasOnly
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('bannerURL' in data) || (data.bannerURL is string && data.bannerURL.size() <= 1000)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 30)) &&
             (!('mpesaPhoneNumber' in data) || (data.mpesaPhoneNumber is string && data.mpesaPhoneNumber.size() <= 30)) &&
             (!('familyRole' in data) || data.familyRole in ["Father", "Mother", "Guardian", "Wife", "Husband", "Son", "Daughter", "Brother", "Sister", "Grandparent", "Relative", "Help"]) &&
             (!('familyId' in data) || data.familyId is string) &&
             (!('familyStatus' in data) || data.familyStatus in ["active", "suspended", "invited"]) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('idDocumentUrl' in data) || (data.idDocumentUrl is string && data.idDocumentUrl.size() <= 1000)) &&
             (!('age' in data) || (data.age is number && data.age >= 0 && data.age <= 150)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('dateOfBirth' in data) || (data.dateOfBirth is string && data.dateOfBirth.size() <= 40)) &&
             (!('currency' in data) || data.currency in ["KES", "USD", "EUR"]) &&
             (!('relationships' in data) || (data.relationships is list && data.relationships.size() <= 100)) &&
             (!('role' in data) || data.role is string && data.role in ['user']); // Do not allow user to set own role to admin
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && (
        isAdmin() || 
        (request.auth.uid == userId && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'isVerified'])) ||
        (incoming().familyId != null && isFamilyOwner(incoming().familyId)) || 
        (existing().familyId != null && isFamilyOwner(existing().familyId))
      ) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    function isValidFamily(data) {
      return data.keys().hasAll(['name', 'ownerId', 'inviteCode']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             (!('createdAt' in data) || data.createdAt is string);
    }
    match /families/{familyId} {
      allow get: if isSignedIn() && isValidId(familyId) && (resource.data.ownerId == request.auth.uid || isFamilyMember(familyId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(familyId) && isValidFamily(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(familyId) && (existing().ownerId == request.auth.uid || isAdmin()) && isValidFamily(incoming()) && incoming().ownerId == existing().ownerId;
      allow delete: if isAdmin();
    }

    function isValidCommunity(data) {
      return data.keys().hasAll(['name', 'creatorId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.creatorId == request.auth.uid &&
             (!('type' in data) || data.type in ["Chama / Table Banking", "Family Network", "Neighbourhood Association", "Welfare Group"]) &&
             (!('memberIds' in data) || (data.memberIds is list && data.memberIds.size() <= 2000)) &&
             (!('moderatorIds' in data) || (data.moderatorIds is list && data.moderatorIds.size() <= 100)) &&
             (!('memberRoles' in data) || data.memberRoles is map) &&
             (!('poolBalance' in data) || data.poolBalance is number) &&
             (!('modules' in data) || (data.modules is list && data.modules.size() <= 30)) &&
             (!('invitationCode' in data) || (data.invitationCode is string && data.invitationCode.size() <= 20)) &&
             (!('privacy' in data) || data.privacy in ["public", "private"]) &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == request.time);
    }
    
    match /communities/{communityId} {
      allow get: if isSignedIn() && isValidId(communityId) && ((resource.data.privacy == "public") || (request.auth.uid in resource.data.memberIds) || isAdmin());
      allow list: if isSignedIn() && ((resource.data.privacy == "public") || (request.auth.uid in resource.data.memberIds) || isAdmin());
      allow create: if isSignedIn() && isValidId(communityId) && isValidCommunity(incoming());
      allow update: if isSignedIn() && isValidId(communityId) && (request.auth.uid in existing().moderatorIds || existing().creatorId == request.auth.uid || isAdmin()) && isValidCommunity(incoming());
      allow delete: if isAdmin();

      match /projects/{projectId} {
         allow get: if isSignedIn() && isValidId(projectId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create: if isSignedIn() && isValidId(projectId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
         allow update: if isSignedIn() && isValidId(projectId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
         allow delete: if isSignedIn() && isValidId(projectId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
      match /assets/{assetId} {
         allow get: if isSignedIn() && isValidId(assetId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create: if isSignedIn() && isValidId(assetId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
         allow update: if isSignedIn() && isValidId(assetId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
         allow delete: if isSignedIn() && isValidId(assetId) && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
      match /bookings/{bookingId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
      }
      match /maintenance/{maintId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
      match /tickets/{ticketId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
      }
      match /records/{recordId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
      match /announcements/{annId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
      match /minutes/{minId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
      match /merryGoRound/{configId} {
         allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.memberIds || isAdmin());
         allow create, update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)).data.moderatorIds || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || isAdmin());
      }
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && isValidId(reportId) && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(reportId) && incoming().reporterId == request.auth.uid && incoming().keys().hasAll(['reporterId', 'targetId', 'reason']) && incoming().reason is string && incoming().reason.size() <= 2000;
      allow update: if isSignedIn() && isValidId(reportId) && isAdmin();
      allow delete: if isSignedIn() && isValidId(reportId) && isAdmin();
    }
    match /support_conversations/{convId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(convId) && isAdmin();
      allow update: if isSignedIn() && isValidId(convId) && (isAdmin() || (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])));
      allow delete: if isSignedIn() && isValidId(convId) && isAdmin();
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/support_conversations/$(convId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isValidId(messageId) && (get(/databases/$(database)/documents/support_conversations/$(convId)).data.userId == request.auth.uid || isAdmin());
      }
    }

    match /habits/{habitId} {
      allow get: if isSignedIn() && isValidId(habitId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(habitId) && incoming().userId == request.auth.uid && incoming().keys().hasAll(['name', 'userId']) && incoming().name is string && incoming().name.size() <= 200;
      allow update: if isSignedIn() && isValidId(habitId) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isValidId(habitId) && existing().userId == request.auth.uid;
    }
    match /shoppingLists/{listId} {
      allow get: if isSignedIn() && isValidId(listId) && (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId));
      allow list: if isSignedIn() && (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId));
      allow create: if isSignedIn() && isValidId(listId) && (!('familyId' in incoming()) || isFamilyMember(incoming().familyId));
      allow update: if isSignedIn() && isValidId(listId) && (!('familyId' in existing()) || isFamilyMember(existing().familyId));
      allow delete: if isSignedIn() && isValidId(listId) && (!('familyId' in existing()) || isFamilyMember(existing().familyId));
    }
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(productId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(productId) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
      allow delete: if isAdmin();
    }
    match /priceRecords/{recordId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recordId) && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin(); // prices should be immutable by users
    }
    match /chores/{choreId} {
      allow get: if isSignedIn() && isValidId(choreId) && (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId) || resource.data.assignedToUserId == request.auth.uid);
      allow list: if isSignedIn() && (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId) || resource.data.assignedToUserId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(choreId) && (!('familyId' in incoming()) || isFamilyMember(incoming().familyId));
      allow update: if isSignedIn() && isValidId(choreId) && (!('familyId' in existing()) || isFamilyMember(existing().familyId));
      allow delete: if isSignedIn() && isValidId(choreId) && (!('familyId' in existing()) || isFamilyMember(existing().familyId));
    }
    match /mealPlans/{planId} {
      allow get, list: if isSignedIn() && (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId));
      allow create: if isSignedIn() && isValidId(planId) && (!('familyId' in incoming()) || isFamilyMember(incoming().familyId));
      allow update, delete: if isSignedIn() && isValidId(planId) && (!('familyId' in existing()) || isFamilyMember(existing().familyId));
    }
    match /expenses/{expenseId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(expenseId) && incoming().userId == request.auth.uid && incoming().keys().hasAll(['amount', 'category', 'userId']) && incoming().amount is number;
      allow update, delete: if isSignedIn() && isValidId(expenseId) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
    }
    match /incomes/{incomeId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(incomeId) && incoming().userId == request.auth.uid && incoming().keys().hasAll(['amount', 'source', 'userId']) && incoming().amount is number;
      allow update, delete: if isSignedIn() && isValidId(incomeId) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
    }
    match /savingsGoals/{goalId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(goalId) && incoming().userId == request.auth.uid && incoming().keys().hasAll(['name', 'targetAmount', 'userId']) && incoming().name is string && incoming().name.size() <= 200;
      allow update, delete: if isSignedIn() && isValidId(goalId) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
    }
    match /loans/{loanId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(loanId) && incoming().userId == request.auth.uid && incoming().keys().hasAll(['amount', 'person', 'type', 'userId']) && incoming().person is string && incoming().person.size() <= 200;
      allow update, delete: if isSignedIn() && isValidId(loanId) && existing().userId == request.auth.uid && incoming().userId == existing().userId;
    }
    match /trips/{tripId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId)));
      allow create: if isSignedIn() && isValidId(tripId) && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isValidId(tripId) && existing().userId == request.auth.uid;
    }
    function isValidWallet(data) {
      return data.keys().hasAll(['userId', 'balance', 'currency']) &&
             data.userId is string && data.balance is number && data.currency is string && data.currency.size() <= 10;
    }
    match /wallets/{walletId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isFamilyOwner(get(/databases/$(database)/documents/users/$(resource.data.userId)).data.familyId));
      allow create: if isSignedIn() && isValidId(walletId) && incoming().userId == request.auth.uid && isValidWallet(incoming());
      allow update: if isSignedIn() && isValidId(walletId) && (existing().userId == request.auth.uid || isAdmin() || isFamilyOwner(get(/databases/$(database)/documents/users/$(existing().userId)).data.familyId)) && 
        isValidWallet(incoming()) && incoming().userId == existing().userId;
      allow delete: if isAdmin();
    }
    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'type', 'transactionDate']) &&
             data.amount is number &&
             data.type in ["transfer", "payment", "deposit", "withdrawal", "reconciliation"] &&
             data.transactionDate is string && data.transactionDate.size() <= 40 &&
             (!('fromUserId' in data) || data.fromUserId is string) &&
             (!('toUserId' in data) || data.toUserId is string) &&
             (!('status' in data) || data.status in ["pending", "completed", "failed"]) &&
             (!('provider' in data) || data.provider is string && data.provider.size() <= 50) &&
             (!('description' in data) || data.description is string && data.description.size() <= 1000) &&
             (!('paymentMethod' in data) || data.paymentMethod is string && data.paymentMethod.size() <= 50) &&
             (!('familyId' in data) || data.familyId is string) &&
             (!('loggedAt' in data) || data.loggedAt is string && data.loggedAt.size() <= 40) &&
             (!('metadata' in data) || data.metadata is map) &&
             (!('createdAt' in data) || (data.createdAt is string || data.createdAt == request.time)) &&
             (!('updatedAt' in data) || (data.updatedAt is string || data.updatedAt == request.time));
    }
    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid || 
        ('familyId' in resource.data && isFamilyMember(resource.data.familyId)) || isAdmin()
      );
      allow create: if isSignedIn() && isValidId(transactionId) && 
        (incoming().fromUserId == request.auth.uid || incoming().toUserId == request.auth.uid) && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidId(transactionId) && (
          isAdmin() ||
          (
            (existing().fromUserId == request.auth.uid || existing().toUserId == request.auth.uid) &&
            isValidTransaction(incoming()) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
            incoming().amount == existing().amount && incoming().fromUserId == existing().fromUserId && incoming().toUserId == existing().toUserId
          )
      );
      allow delete: if isAdmin();
    }
    match /bankAccounts/{accountId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(accountId) && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isValidId(accountId) && existing().userId == request.auth.uid;
    }
    match /messages/{messageId} {
      allow get, list: if isSignedIn() && isFamilyMember(resource.data.familyId);
      allow create: if isSignedIn() && isValidId(messageId) && incoming().senderId == request.auth.uid && isFamilyMember(incoming().familyId) && incoming().text is string && incoming().text.size() <= 10000;
      allow update, delete: if isAdmin();
    }
    match /recipes/{recipeId} {
      allow get, list: if isSignedIn() && (!('familyId' in resource.data) || isFamilyMember(resource.data.familyId));
      allow create: if isSignedIn() && isValidId(recipeId) && (!('familyId' in incoming()) || isFamilyMember(incoming().familyId));
      allow update, delete: if isSignedIn() && isValidId(recipeId) && (!('familyId' in existing()) || isFamilyMember(existing().familyId));
    }
    match /receipts/{receiptId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(receiptId) && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isValidId(receiptId) && existing().userId == request.auth.uid;
    }
    match /joinRequests/{requestId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isFamilyOwner(resource.data.familyId));
      allow create: if isSignedIn() && isValidId(requestId) && incoming().userId == request.auth.uid && exists(/databases/$(database)/documents/families/$(incoming().familyId));
      allow update: if isSignedIn() && isValidId(requestId) && isFamilyOwner(existing().familyId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn() && isValidId(requestId) && existing().userId == request.auth.uid;
    }
    match /growthTasks/{taskId} {
      allow get, list: if isSignedIn() && (isFamilyMember(resource.data.familyId) || isAdmin());
      allow create: if isSignedIn() && isValidId(taskId) && (isFamilyMember(incoming().familyId) || isAdmin());
      allow update, delete: if isSignedIn() && isValidId(taskId) && (isFamilyMember(existing().familyId) || isAdmin());
    }
    match /educationContent/{contentId} {
      allow get, list: if isSignedIn() && (isFamilyMember(resource.data.familyId) || isAdmin());
      allow create: if isSignedIn() && isValidId(contentId) && (isFamilyMember(incoming().familyId) || isAdmin());
      allow update, delete: if isSignedIn() && isValidId(contentId) && (isFamilyMember(existing().familyId) || isAdmin());
    }
    match /achievements/{achievementId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isFamilyMember(get(/databases/$(database)/documents/users/$(resource.data.userId)).data.familyId) || isAdmin());
      allow create, update, delete: if isSignedIn() && isValidId(achievementId) && isAdmin();
    }
    match /reportVerifications/{verificationId} {
      // Intentionally public read for third-party verification logic
      allow get, list: if true;
      allow create, update, delete: if isSignedIn() && isValidId(verificationId) && isAdmin();
    }
    match /forumThreads/{threadId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(threadId) && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(threadId) && ((existing().authorId == request.auth.uid) || incoming().diff(existing()).affectedKeys().hasOnly(['views', 'replyCount']));
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(commentId) && incoming().authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
      }
    }
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(notificationId) && (incoming().userId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && isValidId(notificationId) && (existing().userId == request.auth.uid || isAdmin());
    }
    match /admins/{adminId} {
       allow get, list: if isSignedIn();
       allow create, update, delete: if false; 
    }
    // Added events, private_messages, typing_status, system_notifications, notices, communities root wildcard
    match /events/{eventId} {
      allow get, list: if isSignedIn() && (isFamilyMember(resource.data.familyId) || isAdmin());
      allow create: if isSignedIn() && isValidId(eventId) && (isFamilyMember(incoming().familyId) || isAdmin());
      allow update, delete: if isSignedIn() && isValidId(eventId) && (isFamilyMember(existing().familyId) || isAdmin());
    }
    match /private_messages/{messageId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && isValidId(messageId) && request.auth.uid in incoming().participants && incoming().participants.size() <= 10;
      allow update, delete: if isSignedIn() && isValidId(messageId) && (request.auth.uid in existing().participants || isAdmin());
    }
    match /typing_status/{channelId} {
       allow get, list: if isSignedIn();
       allow create, update, delete: if isSignedIn() && isValidId(channelId);
    }
    match /system_notifications/{notifId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(notifId) && (incoming().userId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && isValidId(notifId) && (existing().userId == request.auth.uid || isAdmin());
    }
    match /notices/{noticeId} {
       allow get, list: if isSignedIn();
       allow create, update, delete: if isSignedIn() && isValidId(noticeId) && isAdmin();
    }
    match /support_tickets/{ticketId} {
       allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
       allow create: if isSignedIn() && isValidId(ticketId) && incoming().userId == request.auth.uid;
       allow update, delete: if isSignedIn() && isValidId(ticketId) && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
